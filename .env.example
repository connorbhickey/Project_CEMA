# ============================================================================
# Project_CEMA — Environment Variable Template
# ============================================================================
# Copy to .env.local for local dev. NEVER commit real values.
# Production secrets live in Vercel Environment Variables.
# ============================================================================

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ─── Database (Neon Postgres) ───────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host/dbname?sslmode=require

# ─── Auth (Clerk) ───────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# ─── WorkOS (Enterprise SSO) ────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ─── Storage (Vercel Blob) ──────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Cache (Upstash Redis) ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── AI Gateway + Providers ─────────────────────────────────────
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Observability ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
BRAINTRUST_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ─── IDP ────────────────────────────────────────────────────────
REDUCTO_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
VAULTEDGE_API_KEY=

# ─── Telephony ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ─── Integration broker (Nango) ─────────────────────────────────
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=

# ─── Email / Calendar (Nylas) ───────────────────────────────────
NYLAS_API_KEY=
NYLAS_CLIENT_ID=

# ─── Email outbound (Resend) ────────────────────────────────────
RESEND_API_KEY=

# ─── CRM unified (Merge.dev) ────────────────────────────────────
MERGE_API_KEY=

# ─── eSignature ─────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=

# ─── Mortgage-specific ──────────────────────────────────────────
DOCMAGIC_USERNAME=
DOCMAGIC_PASSWORD=
SIMPLIFILE_API_KEY=
ENCOMPASS_CLIENT_ID=
ENCOMPASS_CLIENT_SECRET=

# ─── KYC / verification ─────────────────────────────────────────
PERSONA_API_KEY=
TRUEWORK_API_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=

# ─── Notifications (Knock) ──────────────────────────────────────
KNOCK_API_KEY=

# ─── Billing (Stripe + Metronome) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
METRONOME_API_KEY=

# ─── Support (Plain) ────────────────────────────────────────────
PLAIN_API_KEY=

# ─── Feature flags (Vercel Flags) ───────────────────────────────
FLAGS_SECRET=
