# ============================================================================
# Project_CEMA — Environment Variable Template
# ============================================================================
# Copy to .env.local for local dev. NEVER commit real values.
# Production secrets live in Vercel Environment Variables.
# ============================================================================

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ─── Database (Neon Postgres) ───────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host/dbname?sslmode=require

# ─── PII encryption (pgcrypto symmetric key) ────────────────────
# Phase 0/1: single env-provisioned key. Customer-managed keys (KMS-backed,
# per-tenant) are Phase 2 per spec §12.1. Generate via: openssl rand -hex 32.
# Used by packages/compliance/src/ssn.ts via setPiiKey(tx) → SET LOCAL
# inside withRls() callbacks. MUST be ≥ 32 chars or the helpers throw.
PII_ENCRYPTION_KEY=

# ─── Auth (Clerk) ───────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── WorkOS (Enterprise SSO) ────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ─── Storage (Vercel Blob) ──────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Cache (Upstash Redis) ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron jobs (Vercel Cron) ────────────────────────────────────
# M9: recording-retention cron (apps/web/app/api/cron/recording-retention)
# authenticates via `Authorization: Bearer ${CRON_SECRET}`. Set this value
# yourself (e.g. openssl rand -hex 32) in Vercel; Vercel Cron then attaches
# it automatically to scheduled invocations. Without it the route 200s in
# dev but production cron requests should always carry the bearer.
CRON_SECRET=

# ─── AI Gateway + Providers ─────────────────────────────────────
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
# M5: ANTHROPIC_API_KEY powers @cema/search query classifier (claude-sonnet-4-6)
OPENAI_API_KEY=
# M5: OPENAI_API_KEY powers @cema/embeddings (text-embedding-3-large, 3072-dim)
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Full-text search (Typesense Cloud) ─────────────────────────
# M6: @cema/typesense — dev loop works without these (isTypesenseConfigured() gates all calls)
# Sign up at https://cloud.typesense.org and create a cluster.
TYPESENSE_API_KEY=
TYPESENSE_HOST=xxx.a1.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https

# ─── Agent memory (Mem0) ────────────────────────────────────────
# M6: @cema/memory — dev loop works without this (isMemoryConfigured() gates all calls)
# Sign up at https://app.mem0.ai and get an API key.
MEM0_API_KEY=

# ─── Observability ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
BRAINTRUST_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ─── IDP ────────────────────────────────────────────────────────
REDUCTO_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
VAULTEDGE_API_KEY=

# ─── Telephony ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ─── Integration broker (Nango) ─────────────────────────────────
# NANGO_PUBLIC_KEY is not used — Nango v2 uses Connect Sessions instead.
# Server creates a short-lived session token via NANGO_SECRET_KEY; no public
# key reaches the browser. See packages/integrations/nango/src/frontend.ts.
NANGO_SECRET_KEY=
NANGO_HOST=https://api.nango.dev

# ─── Email / Calendar (Nylas) ───────────────────────────────────
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
NYLAS_WEBHOOK_SECRET=
NYLAS_API_URI=https://api.us.nylas.com

# Vercel Queues — topic names (M3 email + M4 Slack, Drive, DocuSign)
VERCEL_QUEUE_EMAIL_TOPIC=comms.email.ingest
VERCEL_QUEUE_SLACK_TOPIC=comms.slack.ingest
VERCEL_QUEUE_DRIVE_TOPIC=files.drive.ingest
VERCEL_QUEUE_DOCUSIGN_TOPIC=esign.docusign.events
VERCEL_QUEUE_EMBED_COMM_TOPIC=comms.embed
VERCEL_QUEUE_EMBED_DOC_TOPIC=docs.embed

# ─── Email outbound (Resend) ────────────────────────────────────
RESEND_API_KEY=

# ─── CRM unified (Merge.dev) ────────────────────────────────────
MERGE_API_KEY=

# ─── Slack ───────────────────────────────────────────────
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ─── Google Drive ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_WEBHOOK_URL=

# ─── eSignature (DocuSign) ────────────────────────────
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_CONNECT_SECRET=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# ─── Mortgage-specific ──────────────────────────────────────────
DOCMAGIC_USERNAME=
DOCMAGIC_PASSWORD=
SIMPLIFILE_API_KEY=
ENCOMPASS_CLIENT_ID=
ENCOMPASS_CLIENT_SECRET=

# ─── KYC / verification ─────────────────────────────────────────
PERSONA_API_KEY=
TRUEWORK_API_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=

# ─── Notifications (Knock) ──────────────────────────────────────
KNOCK_API_KEY=

# ─── Billing (Stripe + Metronome) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
METRONOME_API_KEY=

# ─── Support (Plain) ────────────────────────────────────────────
PLAIN_API_KEY=

# ─── Feature flags (Vercel Flags) ───────────────────────────────
FLAGS_SECRET=
