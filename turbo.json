{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    ".env.example",
    ".eslintrc.cjs",
    ".prettierrc",
    "tsconfig.json"
  ],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"],
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "NEXT_PUBLIC_*",
        "CLERK_*",
        "AI_GATEWAY_API_KEY",
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY",
        "BLOB_READ_WRITE_TOKEN",
        "UPSTASH_REDIS_REST_*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "db:generate": {
      "cache": false,
      "outputs": ["drizzle/**"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:setup": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "eval": {
      "cache": false,
      "outputs": ["eval-results/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
