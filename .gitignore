# ─── Node / pnpm ────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Build outputs ─────────────────────────────────────────────
dist/
build/
.next/
out/
.turbo/
.cache/
.parcel-cache/
*.tsbuildinfo
.swc/
# Next.js regenerates next-env.d.ts on every dev/build with double-quoted
# imports; the file's own header says "This file should not be edited." Per
# Next.js docs (https://nextjs.org/docs/app/api-reference/config/typescript)
# the recommended pattern is to gitignore it. tsc picks it up via tsconfig
# include patterns at typecheck time.
apps/web/next-env.d.ts

# ─── Vercel ────────────────────────────────────────────────────
.vercel
.vercel.json.local

# ─── Environment & secrets — NEVER COMMIT ──────────────────────
.env
.env.local
.env.development.local
.env.preview.local
.env.production.local
.env.*.local
!.env.example
*.pem
*.key
*.p12
*.pfx
*credentials*
*secret*
*token*
!*.example
# Allow documentation files that happen to contain "secret" in the name
!docs/runbooks/github-secrets.md
!docs/**/*-secrets*.md
.npmrc.local

# ─── Editor / IDE ──────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.cursor/
.aider*
.claude/
!.claude/settings.json.example

# ─── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/
playwright/.cache/

# ─── Workflow DevKit (WDK) ─────────────────────────────────────
# Generated by `@workflow/vitest` (test:workflow) and the WDK builders:
#   .workflow-vitest/  — esbuild-compiled step/workflow bundles
#   .workflow-data/    — in-process Local World runtime state
# Both are regenerated on each run; never commit them.
.workflow-data/
.workflow-vitest/

# ─── Drizzle / DB ──────────────────────────────────────────────
drizzle/meta/_journal.json.bak

# ─── Misc ──────────────────────────────────────────────────────
*.log
.history/
tmp/
temp/
*.tgz
.DS_Store?

# ─── Project-specific ──────────────────────────────────────────
# Generated call recordings (use Vercel Blob in prod; never local)
recordings/
# Generated CEMA documents (use Vercel Blob in prod)
generated-docs/
# IDP intermediate files
idp-tmp/

.vercel
.env*.local
